{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "name": "LM Studio",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://host.docker.internal:1234/v1"
      },
      "models": {
        "gemma-4-e4b": {
          "name": "google/gemma-4-e4b"
        },
        "qwen3.5-9b": {
          "name": "qwen/qwen3.5-9b"
        }
      }
    }
  },
  "model": "lmstudio/local-model"
}